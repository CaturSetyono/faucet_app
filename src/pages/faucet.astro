---
// Faucet Page - Cyberpunk Gaming Inspired
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
	<title>Claim PADI Tokens - Gaming Faucet</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,700;0,900;1,700;1,900&display=swap" rel="stylesheet">
	<style>
		body {
			background: linear-gradient(135deg, #0d0d14 0%, #1a1a28 100%);
		}
		.glow-lime {
			text-shadow: 0 0 20px rgba(158, 255, 0, 0.5), 0 0 40px rgba(158, 255, 0, 0.3);
		}
		.glow-box-lime {
			box-shadow: 0 0 30px rgba(158, 255, 0, 0.3), inset 0 0 20px rgba(158, 255, 0, 0.1);
		}
		@keyframes spin {
			to { transform: rotate(360deg); }
		}
		.spinner {
			animation: spin 1s linear infinite;
		}
		.message-enter {
			animation: messageEnter 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		}
		@keyframes messageEnter {
			from {
				opacity: 0;
				transform: scale(0.95) translateY(-10px);
			}
			to {
				opacity: 1;
				transform: scale(1) translateY(0);
			}
		}
		.fade-in-up {
			animation: fadeInUp 0.8s ease-out;
		}
		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		input:focus {
			outline: none;
		}
		.diagonal-stripes {
			background-image: repeating-linear-gradient(
				45deg,
				transparent,
				transparent 10px,
				rgba(158, 255, 0, 0.03) 10px,
				rgba(158, 255, 0, 0.03) 20px
			);
		}
	</style>
</head>
<body class="bg-cyber-black text-white font-roboto antialiased overflow-x-hidden min-h-screen">
	
	<!-- Navigation -->
	<nav class="fixed top-0 w-full z-50 bg-cyber-darker/95 backdrop-blur-md border-b border-white/10">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
			<div class="flex justify-between items-center h-16 sm:h-20">
				<a href="/" class="flex items-center gap-3">
					<div class="w-10 h-10 sm:w-12 sm:h-12 bg-cyber-neon-lime rounded-lg flex items-center justify-center">
						<span class="text-cyber-black font-black text-xl sm:text-2xl">P</span>
					</div>
					<div class="font-black text-xl sm:text-2xl">
						<span class="text-white">Padi</span><span class="text-cyber-neon-lime">Tech</span>
					</div>
				</a>
				<a href="/" 
				   class="px-4 sm:px-6 py-2 sm:py-3 text-gray-400 font-bold hover:text-cyber-neon-lime transition-colors">
					← Back to Home
				</a>
			</div>
		</div>
	</nav>

	<!-- Main Content -->
	<main class="pt-24 sm:pt-32 pb-12 sm:pb-16 px-4 sm:px-6">
		<div class="max-w-7xl mx-auto">
			
			<!-- Header -->
			<div class="text-center mb-10 sm:mb-12 fade-in-up">
				<div class="inline-block px-4 py-2 bg-cyber-neon-lime/10 border border-cyber-neon-lime/30 rounded-full mb-4">
					<span class="text-cyber-neon-lime font-bold text-sm">Free Testnet Distribution</span>
				</div>
				<h1 class="text-4xl sm:text-6xl md:text-7xl font-black mb-4">
					<span class="text-white">Claim Your</span><br/>
					<span class="text-cyber-neon-lime glow-lime">PADI Tokens</span>
				</h1>
				<p class="text-gray-400 text-base sm:text-lg">
					Enter your wallet address to receive testnet tokens instantly
				</p>
			</div>

			<!-- Main Grid Layout -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
				
				<!-- Main Form Card (Left Side - 8 cols) -->
				<div class="lg:col-span-8 bg-cyber-card border border-white/10 rounded-2xl p-6 sm:p-10 fade-in-up" style="animation-delay: 0.1s;">
					<div class="mb-8">
						<h2 class="text-2xl sm:text-3xl font-black text-white mb-2">Token Request</h2>
						<p class="text-gray-400">Submit your wallet address below to claim tokens</p>
					</div>

					<form id="faucet-form" class="space-y-6">
						<div>
							<label for="address" class="block text-sm font-bold text-gray-300 mb-3">
								Wallet Address
							</label>
							<input
								type="text"
								id="address"
								placeholder="0x..."
								required
								autocomplete="off"
								spellcheck="false"
								class="w-full px-5 py-4 bg-cyber-darker border-2 border-white/10 text-white placeholder-gray-600 rounded-xl focus:border-cyber-neon-lime focus:ring-2 focus:ring-cyber-neon-lime/20 transition-all font-mono text-sm sm:text-base"
							/>
						</div>
						
						<button
							type="submit"
							id="submit-btn"
							class="w-full px-6 py-5 bg-cyber-neon-lime text-cyber-black font-black text-lg rounded-xl hover:bg-cyber-neon-blue hover:text-white transition-all duration-300 transform hover:scale-[1.02] active:scale-95 touch-manipulation disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none shadow-lg hover:shadow-cyber-neon-lime/50"
						>
							<span id="button-text">Request Tokens</span>
							<svg id="loading-spinner" class="hidden spinner inline-block w-6 h-6 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
							</svg>
						</button>
					</form>

					<!-- Message Box -->
					<div id="message-box" class="mt-6 hidden"></div>
				</div>

				<!-- Sidebar Cards (Right Side - 4 cols) -->
				<div class="lg:col-span-4 space-y-4">
					
					<!-- Cart Header -->
					<div class="flex items-center justify-between mb-2 px-2">
						<h3 class="text-xl font-black text-white">CLAIM CART</h3>
						<span class="text-sm text-gray-400">1 item selected</span>
					</div>

					<!-- Amount Card -->
					<div class="bg-gradient-to-br from-cyber-neon-lime/20 to-cyber-neon-lime/5 border border-cyber-neon-lime/30 rounded-2xl p-6 hover:border-cyber-neon-lime hover:shadow-lg hover:shadow-cyber-neon-lime/30 transition-all duration-300 fade-in-up" style="animation-delay: 0.2s;">
						<div class="flex items-center justify-between mb-4">
							<div>
								<div class="text-xs text-gray-400 mb-1 font-medium uppercase tracking-wider">PADI Token</div>
								<div class="font-black text-2xl text-white">1000 PADI</div>
							</div>
							<div class="w-12 h-12 bg-cyber-neon-lime rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-6 h-6 text-cyber-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
								</svg>
							</div>
						</div>
						<div class="flex items-center justify-between pt-4 border-t border-white/10">
							<span class="text-xs text-gray-400">Per Claim</span>
							<span class="flex items-center gap-2">
								<span class="w-2 h-2 bg-cyber-neon-lime rounded-full animate-pulse"></span>
								<span class="text-xs text-cyber-neon-lime font-bold">Available</span>
							</span>
						</div>
					</div>

					<!-- Network Card -->
					<div class="bg-gradient-to-br from-cyber-neon-blue/20 to-cyber-neon-blue/5 border border-cyber-neon-blue/30 rounded-2xl p-6 hover:border-cyber-neon-blue hover:shadow-lg hover:shadow-cyber-neon-blue/30 transition-all duration-300 fade-in-up" style="animation-delay: 0.3s;">
						<div class="flex items-center justify-between mb-4">
							<div>
								<div class="text-xs text-gray-400 mb-1 font-medium uppercase tracking-wider">Network</div>
								<div class="font-black text-xl text-white">Sepolia</div>
							</div>
							<div class="w-12 h-12 bg-cyber-neon-blue rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
								</svg>
							</div>
						</div>
						<div class="text-xs text-gray-400">Ethereum Testnet</div>
					</div>

					<!-- Status Card -->
					<div class="bg-cyber-card border border-white/10 rounded-2xl p-6 hover:border-white/20 transition-all duration-300 fade-in-up" style="animation-delay: 0.4s;">
						<div class="flex items-center justify-between mb-4">
							<div>
								<div class="text-xs text-gray-400 mb-1 font-medium uppercase tracking-wider">Status</div>
								<div class="font-black text-xl text-white">Online</div>
							</div>
							<div class="w-12 h-12 bg-cyber-neon-pink/20 border-2 border-cyber-neon-pink rounded-lg flex items-center justify-center flex-shrink-0">
								<svg class="w-6 h-6 text-cyber-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
								</svg>
							</div>
						</div>
						<div class="text-xs text-gray-400">24/7 Active Distribution</div>
					</div>

					<!-- Total Price Card -->
					<div class="bg-gradient-to-r from-cyber-neon-lime/10 to-transparent border border-cyber-neon-lime/30 rounded-2xl p-6 fade-in-up diagonal-stripes" style="animation-delay: 0.5s;">
						<div class="flex items-center justify-between">
							<span class="text-gray-400 font-medium">Total Price:</span>
							<span class="font-black text-3xl text-cyber-neon-lime glow-lime">FREE</span>
						</div>
					</div>
				</div>
			</div>

			<!-- Contract Info -->
			<div class="mt-8 bg-cyber-card border border-white/10 rounded-2xl p-6 sm:p-8 fade-in-up" style="animation-delay: 0.6s;">
				<h3 class="font-black text-xl sm:text-2xl mb-6 text-white">Contract Information</h3>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
					<div class="bg-cyber-darker rounded-xl p-5 border-l-4 border-cyber-neon-lime hover:bg-cyber-dark transition-all duration-300">
						<div class="text-xs text-gray-400 mb-2 font-medium uppercase tracking-wider">Contract Address</div>
						<div class="font-mono text-xs text-cyber-neon-lime break-all">0x48fe28f7893de0d20b31fbabca1fdbe318fa339e</div>
					</div>
					<div class="bg-cyber-darker rounded-xl p-5 border-l-4 border-cyber-neon-blue hover:bg-cyber-dark transition-all duration-300">
						<div class="text-xs text-gray-400 mb-2 font-medium uppercase tracking-wider">Token Symbol</div>
						<div class="font-black text-2xl text-cyber-neon-blue">PADI</div>
					</div>
					<div class="bg-cyber-darker rounded-xl p-5 border-l-4 border-cyber-neon-pink hover:bg-cyber-dark transition-all duration-300">
						<div class="text-xs text-gray-400 mb-2 font-medium uppercase tracking-wider">Decimals</div>
						<div class="font-black text-2xl text-cyber-neon-pink">18</div>
					</div>
					<div class="bg-cyber-darker rounded-xl p-5 border-l-4 border-cyber-neon-yellow hover:bg-cyber-dark transition-all duration-300">
						<div class="text-xs text-gray-400 mb-2 font-medium uppercase tracking-wider">Chain ID</div>
						<div class="font-black text-2xl text-cyber-neon-yellow">11155111</div>
					</div>
				</div>
			</div>

			<!-- Instructions -->
			<div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-6">
				<div class="bg-cyber-card border border-white/10 rounded-2xl p-6 sm:p-8 hover:border-cyber-neon-lime/50 hover:-translate-y-1 transition-all duration-300 fade-in-up" style="animation-delay: 0.7s;">
					<div class="w-14 h-14 bg-cyber-neon-lime/10 border-2 border-cyber-neon-lime rounded-xl text-cyber-neon-lime flex items-center justify-center font-black text-2xl mb-5">
						1
					</div>
					<h4 class="font-black text-lg mb-2 text-white">Setup Network</h4>
					<p class="text-gray-400 text-sm">Configure MetaMask with Sepolia network settings</p>
				</div>
				<div class="bg-cyber-card border border-white/10 rounded-2xl p-6 sm:p-8 hover:border-cyber-neon-blue/50 hover:-translate-y-1 transition-all duration-300 fade-in-up" style="animation-delay: 0.8s;">
					<div class="w-14 h-14 bg-cyber-neon-blue/10 border-2 border-cyber-neon-blue rounded-xl text-cyber-neon-blue flex items-center justify-center font-black text-2xl mb-5">
						2
					</div>
					<h4 class="font-black text-lg mb-2 text-white">Enter Address</h4>
					<p class="text-gray-400 text-sm">Paste your wallet address in the form</p>
				</div>
				<div class="bg-cyber-card border border-white/10 rounded-2xl p-6 sm:p-8 hover:border-cyber-neon-pink/50 hover:-translate-y-1 transition-all duration-300 fade-in-up" style="animation-delay: 0.9s;">
					<div class="w-14 h-14 bg-cyber-neon-pink/10 border-2 border-cyber-neon-pink rounded-xl text-cyber-neon-pink flex items-center justify-center font-black text-2xl mb-5">
						3
					</div>
					<h4 class="font-black text-lg mb-2 text-white">Receive Tokens</h4>
					<p class="text-gray-400 text-sm">Get your tokens delivered instantly</p>
				</div>
			</div>
		</div>
	</main>

	<!-- Footer -->
	<footer class="border-t border-white/10 py-10 px-4 sm:px-6 bg-cyber-darker mt-12">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-col sm:flex-row justify-between items-center gap-4">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 bg-cyber-neon-lime rounded-lg flex items-center justify-center">
						<span class="text-cyber-black font-black text-xl">P</span>
					</div>
					<div class="font-black text-xl">
						<span class="text-white">Padi</span><span class="text-cyber-neon-lime">Tech</span>
					</div>
				</div>
				<p class="text-gray-400 text-sm">
					Powered by <span class="text-cyber-neon-blue font-bold">Ethereum</span> • Built with <span class="text-cyber-neon-lime font-bold">Astro</span>
				</p>
			</div>
		</div>
	</footer>

	<!-- Client-side Script -->
	<script>
		const form = document.getElementById('faucet-form');
		const addressInput = document.getElementById('address');
		const submitBtn = document.getElementById('submit-btn');
		const buttonText = document.getElementById('button-text');
		const loadingSpinner = document.getElementById('loading-spinner');
		const messageBox = document.getElementById('message-box');

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			const address = addressInput.value.trim();
			if (!address) return;

			// Reset message
			messageBox.className = 'mt-6 hidden';
			messageBox.innerHTML = '';

			// Loading state
			submitBtn.disabled = true;
			buttonText.textContent = 'Processing...';
			loadingSpinner.classList.remove('hidden');

			try {
				const response = await fetch('/api/faucet', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ address }),
				});

				const data = await response.json();

				if (response.ok) {
					// Success
					messageBox.className = 'mt-6 bg-gradient-to-br from-cyber-neon-lime/20 to-cyber-neon-lime/5 border border-cyber-neon-lime rounded-2xl p-6 sm:p-8 message-enter';
					let htmlMsg = `
						<div class="flex items-start gap-4">
							<div class="w-12 h-12 bg-cyber-neon-lime rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg shadow-cyber-neon-lime/50">
								<svg class="w-6 h-6 text-cyber-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
								</svg>
							</div>
							<div class="flex-1 min-w-0">
								<div class="font-black text-2xl text-cyber-neon-lime glow-lime mb-2">Success!</div>
								<div class="text-gray-300 mb-4">${data.message}</div>
					`;
					if (data.txHash) {
						htmlMsg += `
								<a href="https://sepolia.etherscan.io/tx/${data.txHash}" 
								   target="_blank" 
								   class="inline-flex items-center gap-2 px-6 py-3 bg-cyber-neon-blue text-white font-bold rounded-xl hover:bg-cyber-neon-lime hover:text-cyber-black transition-all duration-300 active:scale-95 touch-manipulation shadow-lg hover:shadow-cyber-neon-blue/50">
									View on Etherscan
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
									</svg>
								</a>
						`;
					}
					htmlMsg += `
							</div>
						</div>
					`;
					messageBox.innerHTML = htmlMsg;
					addressInput.value = '';
				} else {
					// Error
					messageBox.className = 'mt-6 bg-gradient-to-br from-cyber-neon-pink/20 to-cyber-neon-pink/5 border border-cyber-neon-pink rounded-2xl p-6 sm:p-8 message-enter';
					messageBox.innerHTML = `
						<div class="flex items-start gap-4">
							<div class="w-12 h-12 bg-cyber-neon-pink/20 border-2 border-cyber-neon-pink rounded-xl flex items-center justify-center flex-shrink-0">
								<svg class="w-6 h-6 text-cyber-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
								</svg>
							</div>
							<div class="flex-1 min-w-0">
								<div class="font-black text-2xl text-cyber-neon-pink mb-2">Transaction Failed</div>
								<div class="text-gray-300 break-words">${data.error || 'An error occurred'}</div>
								${data.details ? `<div class="text-sm text-gray-400 mt-2 break-words">${data.details}</div>` : ''}
							</div>
						</div>
					`;
				}
			} catch (error) {
				messageBox.className = 'mt-6 bg-gradient-to-br from-cyber-neon-pink/20 to-cyber-neon-pink/5 border border-cyber-neon-pink rounded-2xl p-6 sm:p-8 message-enter';
				messageBox.innerHTML = `
					<div class="flex items-start gap-4">
						<div class="w-12 h-12 bg-cyber-neon-pink/20 border-2 border-cyber-neon-pink rounded-xl flex items-center justify-center flex-shrink-0">
							<svg class="w-6 h-6 text-cyber-neon-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
							</svg>
						</div>
						<div class="flex-1 min-w-0">
							<div class="font-black text-2xl text-cyber-neon-pink mb-2">Network Error</div>
							<div class="text-gray-300">Failed to connect to server</div>
						</div>
					</div>
				`;
				console.error('Fetch error:', error);
			} finally {
				submitBtn.disabled = false;
				buttonText.textContent = 'Request Tokens';
				loadingSpinner.classList.add('hidden');
			}
		});
	</script>

	<!-- Lenis Smooth Scroll -->
	<script>
		import Lenis from 'lenis'

		const lenis = new Lenis({
			duration: 1.2,
			easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			smoothWheel: true,
			smoothTouch: false,
		})

		function raf(time) {
			lenis.raf(time)
			requestAnimationFrame(raf)
		}

		requestAnimationFrame(raf)
	</script>
</body>
</html>
