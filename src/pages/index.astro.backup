---
// Ini adalah bagian server-side Astro (hanya berjalan di server saat halaman di-render)
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Web3 Stablecoin Faucet</title>
		<style>
			/* CSS Vanilla dengan Tema Gelap & Glassmorphism */
			:root {
				--bg-color: #0f172a;
				--text-color: #f8fafc;
				--primary-color: #3b82f6;
				--primary-hover: #2563eb;
				--glass-bg: rgba(255, 255, 255, 0.05);
				--glass-border: rgba(255, 255, 255, 0.1);
				--error-color: #ef4444;
				--success-color: #10b981;
			}

			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
				font-family:
					"Inter",
					system-ui,
					-apple-system,
					sans-serif;
			}

			body {
				background-color: var(--bg-color);
				color: var(--text-color);
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 20px;
				/* Tambahkan efek background glow tipis */
				background-image: radial-gradient(
					circle at 50% 0%,
					rgba(59, 130, 246, 0.15),
					transparent 50%
				);
			}

			.container {
				width: 100%;
				max-width: 400px; /* Ukuran pas untuk mobile, rapi di desktop */
			}

			.glass-card {
				background: var(--glass-bg);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				border: 1px solid var(--glass-border);
				border-radius: 20px;
				padding: 30px;
				box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
			}

			.header {
				text-align: center;
				margin-bottom: 30px;
			}

			.header h1 {
				font-size: 1.8rem;
				margin-bottom: 10px;
				background: linear-gradient(to right, #60a5fa, #a78bfa);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			.header p {
				color: #94a3b8;
				font-size: 0.9rem;
				line-height: 1.5;
			}

			.form-group {
				margin-bottom: 20px;
			}

			.form-group label {
				display: block;
				margin-bottom: 8px;
				font-size: 0.9rem;
				color: #cbd5e1;
			}

			input[type="text"] {
				width: 100%;
				padding: 12px 16px;
				border-radius: 10px;
				background: rgba(0, 0, 0, 0.2);
				border: 1px solid var(--glass-border);
				color: white;
				font-size: 1rem;
				transition: all 0.3s ease;
			}

			input[type="text"]:focus {
				outline: none;
				border-color: var(--primary-color);
				box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
			}

			button {
				width: 100%;
				padding: 14px;
				border: none;
				border-radius: 10px;
				background-color: var(--primary-color);
				color: white;
				font-size: 1rem;
				font-weight: 600;
				cursor: pointer;
				transition:
					background-color 0.3s ease,
					transform 0.1s ease;
			}

			button:hover:not(:disabled) {
				background-color: var(--primary-hover);
			}

			button:active:not(:disabled) {
				transform: scale(0.98);
			}

			button:disabled {
				background-color: #475569;
				cursor: not-allowed;
				opacity: 0.7;
			}

			#message-box {
				margin-top: 20px;
				padding: 12px;
				border-radius: 8px;
				font-size: 0.9rem;
				text-align: center;
				display: none; /* Disembunyikan awalnya */
				word-break: break-all;
			}

			.success {
				background-color: rgba(16, 185, 129, 0.1);
				color: var(--success-color);
				border: 1px solid rgba(16, 185, 129, 0.2);
				display: block !important;
			}

			.error {
				background-color: rgba(239, 68, 68, 0.1);
				color: var(--error-color);
				border: 1px solid rgba(239, 68, 68, 0.2);
				display: block !important;
			}

			.tx-link {
				color: var(--primary-color);
				text-decoration: underline;
				margin-top: 5px;
				display: inline-block;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<div class="glass-card">
				<div class="header">
					<h1>Stablecoin Faucet</h1>
					<p>
						Dapatkan token gratis untuk testnet. Masukkan alamat
						dompet (wallet) kamu di bawah ini.
					</p>
				</div>

				<form id="faucet-form">
					<div class="form-group">
						<label for="address">Wallet Address</label>
						<input
							type="text"
							id="address"
							placeholder="0x..."
							required
							autocomplete="off"
							spellcheck="false"
						/>
					</div>
					<button type="submit" id="submit-btn">Minta Token</button>
				</form>

				<div id="message-box"></div>
			</div>
		</div>

		<!-- Script Client-Side (Berjalan di browser pengguna) -->
		<script>
			const form = document.getElementById("faucet-form");
			const addressInput = document.getElementById("address");
			const submitBtn = document.getElementById("submit-btn");
			const messageBox = document.getElementById("message-box");

			form.addEventListener("submit", async (e) => {
				// Mencegah halaman refresh saat submit
				e.preventDefault();

				const address = addressInput.value.trim();
				if (!address) return;

				// Reset tampilan
				messageBox.className = "";
				messageBox.innerHTML = "";

				// Ubah tombol jadi loading
				submitBtn.disabled = true;
				submitBtn.textContent = "Memproses Transaksi...";

				try {
					// Panggil API Endpoint Astro kita
					const response = await fetch("/api/faucet", {
						method: "POST",
						headers: {
							"Content-Type": "application/json",
						},
						body: JSON.stringify({ address }),
					});

					const data = await response.json();

					if (response.ok) {
						// Jika berhasil
						messageBox.className = "success";
						let htmlMsg = `<strong>Sukses!</strong><br>${data.message}`;
						if (data.txHash) {
							htmlMsg += `<br><a href="https://sepolia.etherscan.io/tx/${data.txHash}" target="_blank" class="tx-link">Lihat Transaksi</a>`;
						}
						messageBox.innerHTML = htmlMsg;
						addressInput.value = ""; // Kosongkan input
					} else {
						// Jika ada error dari server
						messageBox.className = "error";
						messageBox.innerHTML = `<strong>Gagal:</strong><br>${data.error || "Terjadi kesalahan"}`;
					}
				} catch (error) {
					// Jika tidak bisa konek ke server
					messageBox.className = "error";
					messageBox.innerHTML = `<strong>Error:</strong><br>Permintaan gagal dikirim.`;
					console.error("Fetch error:", error);
				} finally {
					// Kembalikan tombol ke semula
					submitBtn.disabled = false;
					submitBtn.textContent = "Minta Token";
				}
			});
		</script>
	</body>
</html>
