---
// Landing Page - Cyberpunk Gaming Inspired
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
	<title>PadiTech Faucet - PADI TOKENS</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,700;0,900;1,700;1,900&display=swap" rel="stylesheet">
	<style>
		body {
			background: linear-gradient(135deg, #0d0d14 0%, #1a1a28 100%);
		}
		.glow-lime {
			text-shadow: 0 0 20px rgba(158, 255, 0, 0.5), 0 0 40px rgba(158, 255, 0, 0.3);
		}
		.glow-blue {
			text-shadow: 0 0 20px rgba(65, 105, 225, 0.5), 0 0 40px rgba(65, 105, 225, 0.3);
		}
		.glow-box-lime {
			box-shadow: 0 0 30px rgba(158, 255, 0, 0.3), inset 0 0 20px rgba(158, 255, 0, 0.1);
		}
		.glow-box-blue {
			box-shadow: 0 0 30px rgba(65, 105, 225, 0.3), inset 0 0 20px rgba(65, 105, 225, 0.1);
		}
		.fade-in-up {
			animation: fadeInUp 0.8s ease-out;
		}
		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		.diagonal-stripes {
			background-image: repeating-linear-gradient(
				45deg,
				transparent,
				transparent 10px,
				rgba(158, 255, 0, 0.05) 10px,
				rgba(158, 255, 0, 0.05) 20px
			);
		}
	</style>
</head>
<body class="bg-cyber-black text-white font-roboto antialiased overflow-x-hidden">
	
	<!-- Navigation -->
	<nav class="fixed top-0 w-full z-50 bg-cyber-darker/95 backdrop-blur-md border-b border-white/10">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-12">
			<div class="flex justify-between items-center h-16 sm:h-20">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 sm:w-12 sm:h-12 bg-cyber-neon-lime rounded-lg flex items-center justify-center">
						<span class="text-cyber-black font-black text-xl sm:text-2xl">P</span>
					</div>
					<div class="font-black text-xl sm:text-2xl">
						<span class="text-white">Padi</span><span class="text-cyber-neon-lime">Tech</span>
					</div>
				</div>
				<a href="/faucet" 
				   class="px-6 sm:px-8 py-2.5 sm:py-3 bg-cyber-neon-lime text-cyber-black font-bold rounded-lg hover:bg-cyber-neon-blue hover:text-white transition-all duration-300 active:scale-95 touch-manipulation shadow-lg hover:shadow-cyber-neon-lime/50">
					Launch Faucet
				</a>
			</div>
		</div>
	</nav>

	<!-- Hero Section -->
	<section class="min-h-screen flex items-center justify-center px-4 sm:px-6 pt-24 sm:pt-32 pb-12 relative">
		<div class="absolute inset-0 diagonal-stripes opacity-30"></div>
		<div class="max-w-7xl w-full relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
				
				<!-- Left Side - Hero Content -->
				<div class="fade-in-up">
					<div class="inline-block px-4 py-2 bg-cyber-neon-lime/10 border border-cyber-neon-lime/30 rounded-full mb-6">
						<span class="text-cyber-neon-lime font-bold text-sm uppercase tracking-wider">Free Testnet Tokens</span>
					</div>
					<h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-none mb-6">
						<span class="text-white">Ultimate</span><br/>
						<span class="text-cyber-neon-lime glow-lime">PADI WARS</span>
					</h1>
					<p class="text-lg sm:text-xl text-gray-300 mb-8 max-w-xl leading-relaxed">
						Embark on your Web3 journey with PADI tokens. A decentralized faucet that empowers developers on Sepolia testnet with instant token distribution.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="/faucet" 
						   class="px-8 py-4 bg-cyber-neon-lime text-cyber-black font-bold text-lg rounded-xl hover:bg-cyber-neon-blue hover:text-white transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-xl hover:shadow-cyber-neon-lime/50 text-center">
							Claim Tokens Now
						</a>
						<a href="#about" 
						   class="px-8 py-4 bg-cyber-card text-white font-bold text-lg rounded-xl border border-white/10 hover:border-cyber-neon-blue hover:bg-cyber-dark transition-all duration-300 text-center">
							Learn More
						</a>
					</div>
				</div>

				<!-- Right Side - Feature Cards -->
				<div class="grid grid-cols-1 gap-4 fade-in-up" style="animation-delay: 0.2s;">
					
					<!-- Top Card - Amount -->
					<div class="bg-gradient-to-br from-cyber-neon-lime/20 to-cyber-neon-lime/5 border border-cyber-neon-lime/30 rounded-2xl p-6 sm:p-8 hover:border-cyber-neon-lime hover:shadow-lg hover:shadow-cyber-neon-lime/30 transition-all duration-300">
						<div class="flex items-center justify-between mb-4">
							<div>
								<div class="text-sm text-gray-400 mb-1 font-medium">ANBU WARS</div>
								<div class="font-black text-2xl sm:text-3xl text-white">1000 PADI Tokens</div>
							</div>
							<div class="w-14 h-14 bg-cyber-neon-lime rounded-xl flex items-center justify-center">
								<svg class="w-8 h-8 text-cyber-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
								</svg>
							</div>
						</div>
						<div class="text-xs text-gray-400">Release: 2024</div>
					</div>

					<!-- Middle Card - Network -->
					<div class="bg-gradient-to-br from-cyber-neon-blue/20 to-cyber-neon-blue/5 border border-cyber-neon-blue/30 rounded-2xl p-6 sm:p-8 hover:border-cyber-neon-blue hover:shadow-lg hover:shadow-cyber-neon-blue/30 transition-all duration-300">
						<div class="flex items-center justify-between mb-4">
							<div>
								<div class="text-sm text-gray-400 mb-1 font-medium">ETHEREUM TESTNET</div>
								<div class="font-black text-2xl sm:text-3xl text-white">Sepolia Network</div>
							</div>
							<div class="w-14 h-14 bg-cyber-neon-blue rounded-xl flex items-center justify-center">
								<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
								</svg>
							</div>
						</div>
						<div class="text-xs text-gray-400">Chain ID: 11155111</div>
					</div>

					<!-- Bottom Card - Status -->
					<div class="bg-cyber-card border border-white/10 rounded-2xl p-6 sm:p-8 hover:border-white/20 transition-all duration-300">
						<div class="flex items-center justify-between">
							<div>
								<div class="text-sm text-gray-400 mb-2 font-medium">FAUCET STATUS</div>
								<div class="flex items-center gap-3">
									<span class="w-3 h-3 bg-cyber-neon-lime rounded-full animate-pulse shadow-lg shadow-cyber-neon-lime/50"></span>
									<span class="font-bold text-xl text-white">Active 24/7</span>
								</div>
							</div>
							<div class="text-right">
								<div class="font-black text-3xl text-cyber-neon-lime glow-lime">∞</div>
								<div class="text-xs text-gray-400">Available</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Game Genre Section (How It Works) -->
	<section id="about" class="py-16 sm:py-24 px-4 sm:px-6 bg-cyber-darker/50">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-12 sm:mb-16">
				<h2 class="text-3xl sm:text-5xl md:text-6xl font-black mb-4">
					<span class="text-white">How It</span> <span class="text-cyber-neon-lime glow-lime">Works</span>
				</h2>
				<p class="text-gray-400 text-lg">Three simple steps to claim your tokens</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
				<!-- Step 1 -->
				<div class="bg-cyber-card border border-white/10 rounded-2xl p-8 hover:border-cyber-neon-lime/50 hover:-translate-y-2 transition-all duration-300 group">
					<div class="w-16 h-16 bg-cyber-neon-lime/10 border-2 border-cyber-neon-lime rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyber-neon-lime group-hover:scale-110 transition-all duration-300">
						<span class="text-3xl font-black text-cyber-neon-lime group-hover:text-cyber-black">1</span>
					</div>
					<h3 class="text-2xl font-black mb-3 text-white">Connect Wallet</h3>
					<p class="text-gray-400">Configure MetaMask with Sepolia testnet and ensure you're connected to the right network.</p>
				</div>

				<!-- Step 2 -->
				<div class="bg-cyber-card border border-white/10 rounded-2xl p-8 hover:border-cyber-neon-blue/50 hover:-translate-y-2 transition-all duration-300 group">
					<div class="w-16 h-16 bg-cyber-neon-blue/10 border-2 border-cyber-neon-blue rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyber-neon-blue group-hover:scale-110 transition-all duration-300">
						<span class="text-3xl font-black text-cyber-neon-blue group-hover:text-white">2</span>
					</div>
					<h3 class="text-2xl font-black mb-3 text-white">Enter Address</h3>
					<p class="text-gray-400">Paste your wallet address in the faucet form and submit your request for tokens.</p>
				</div>

				<!-- Step 3 -->
				<div class="bg-cyber-card border border-white/10 rounded-2xl p-8 hover:border-cyber-neon-pink/50 hover:-translate-y-2 transition-all duration-300 group">
					<div class="w-16 h-16 bg-cyber-neon-pink/10 border-2 border-cyber-neon-pink rounded-xl flex items-center justify-center mb-6 group-hover:bg-cyber-neon-pink group-hover:scale-110 transition-all duration-300">
						<span class="text-3xl font-black text-cyber-neon-pink group-hover:text-white">3</span>
					</div>
					<h3 class="text-2xl font-black mb-3 text-white">Receive Tokens</h3>
					<p class="text-gray-400">Get 1000 PADI tokens instantly sent to your wallet. Start building your dApp immediately.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Tech Specs Section -->
	<section id="specs" class="py-16 sm:py-24 px-4 sm:px-6">
		<div class="max-w-7xl mx-auto">
			<div class="text-center mb-12 sm:mb-16">
				<h2 class="text-3xl sm:text-5xl md:text-6xl font-black mb-4">
					<span class="text-white">Technical</span> <span class="text-cyber-neon-blue glow-blue">Specifications</span>
				</h2>
				<p class="text-gray-400 text-lg">Smart contract details and token information</p>
			</div>
			
			<div class="bg-cyber-card border border-white/10 rounded-3xl p-8 sm:p-12">
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					<div class="bg-cyber-darker rounded-xl p-6 border-l-4 border-cyber-neon-lime hover:bg-cyber-dark transition-all duration-300">
						<div class="text-sm text-gray-400 mb-2 font-medium">Token Name</div>
						<div class="font-black text-2xl text-cyber-neon-lime">PADITECH</div>
						<div class="text-sm text-gray-500 mt-1">(PADI)</div>
					</div>
					<div class="bg-cyber-darker rounded-xl p-6 border-l-4 border-cyber-neon-blue hover:bg-cyber-dark transition-all duration-300">
						<div class="text-sm text-gray-400 mb-2 font-medium">Contract Address</div>
						<div class="font-mono text-xs text-cyber-neon-blue break-all">0x48fe28...fa339e</div>
					</div>
					<div class="bg-cyber-darker rounded-xl p-6 border-l-4 border-cyber-neon-pink hover:bg-cyber-dark transition-all duration-300">
						<div class="text-sm text-gray-400 mb-2 font-medium">Network</div>
						<div class="font-black text-2xl text-cyber-neon-pink">Sepolia</div>
						<div class="text-sm text-gray-500 mt-1">Ethereum Testnet</div>
					</div>
					<div class="bg-cyber-darker rounded-xl p-6 border-l-4 border-cyber-neon-yellow hover:bg-cyber-dark transition-all duration-300">
						<div class="text-sm text-gray-400 mb-2 font-medium">Decimals</div>
						<div class="font-black text-2xl text-cyber-neon-yellow">18</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="py-16 sm:py-24 px-4 sm:px-6 bg-gradient-to-br from-cyber-neon-lime/10 to-cyber-neon-blue/10">
		<div class="max-w-4xl mx-auto text-center">
			<div class="bg-cyber-card border border-cyber-neon-lime/30 rounded-3xl p-12 sm:p-16 glow-box-lime">
				<h2 class="text-4xl sm:text-5xl md:text-6xl font-black mb-6">
					<span class="text-white">Ready to Start</span><br/>
					<span class="text-cyber-neon-lime glow-lime">Building?</span>
				</h2>
				<p class="text-gray-300 mb-10 text-lg sm:text-xl">
					Claim your free testnet tokens and begin your Web3 development journey today
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="/faucet" 
					   class="px-12 py-5 bg-cyber-neon-lime text-cyber-black font-black text-xl rounded-xl hover:bg-cyber-neon-blue hover:text-white transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-2xl hover:shadow-cyber-neon-lime/50">
						Launch Faucet
					</a>
					<div class="flex items-center justify-center gap-3 px-8 py-5 bg-cyber-darker rounded-xl border border-white/10">
						<span class="text-gray-400 font-medium">Total Price:</span>
						<span class="font-black text-2xl text-cyber-neon-lime">FREE</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="border-t border-white/10 py-10 px-4 sm:px-6 bg-cyber-darker">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-col sm:flex-row justify-between items-center gap-4">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 bg-cyber-neon-lime rounded-lg flex items-center justify-center">
						<span class="text-cyber-black font-black text-xl">P</span>
					</div>
					<div class="font-black text-xl">
						<span class="text-white">Padi</span><span class="text-cyber-neon-lime">Tech</span>
					</div>
				</div>
				<p class="text-gray-400 text-sm">
					Powered by <span class="text-cyber-neon-blue font-bold">Ethereum</span> • Built with <span class="text-cyber-neon-lime font-bold">Astro</span>
				</p>
			</div>
		</div>
	</footer>

	<!-- Lenis Smooth Scroll -->
	<script>
		import Lenis from 'lenis'

		const lenis = new Lenis({
			duration: 1.2,
			easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			smoothWheel: true,
			smoothTouch: false,
		})

		function raf(time) {
			lenis.raf(time)
			requestAnimationFrame(raf)
		}

		requestAnimationFrame(raf)
	</script>
</body>
</html>
